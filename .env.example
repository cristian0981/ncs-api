# ============================================================
#  Configuración del Bot de Control de No Conformidades (NC)
#  Copiar este archivo como .env y completar los valores.
# ============================================================

# --- App ---
APP_NAME="Bot Control NC - Celsia/ISES"
ENVIRONMENT=development            # development | production
DEBUG=true
API_V1_PREFIX=/api

# --- CORS (frontend Angular) ---
# Lista separada por comas de orígenes permitidos.
BACKEND_CORS_ORIGINS=http://localhost:4200

# --- Base de datos LOCAL de control (SQLite por defecto) ---
LOCAL_DATABASE_URL=sqlite:///./data/control_nc.db

# --- Base de datos de ORIGEN (Formap) - solo lectura ---
# Dejar vacío hasta tener credenciales. Ejemplos por motor:
#   SQL Server : mssql+pyodbc://USER:PASS@HOST:1433/DB?driver=ODBC+Driver+17+for+SQL+Server
#   PostgreSQL : postgresql+psycopg2://USER:PASS@HOST:5432/DB
#   MySQL      : mysql+pymysql://USER:PASS@HOST:3306/DB
ORIGIN_DATABASE_URL=
# Nombre de la tabla/vista de origen y el valor que marca una NC
ORIGIN_NC_TABLE=actividades
ORIGIN_NC_CALIFICACION_VALUE=NC

# --- SLA (días) ---
SLA_DIAS_NOTIFICACION=8            # días hábiles para notificar desde la ejecución
SLA_DIAS_VALIDACION_ISES=5         # días hábiles de ISES para validar la respuesta
SLA_PAIS_FESTIVOS=CO              # código de país para la librería 'holidays'

# --- Microsoft Graph (se habilita en la Semana 2) ---
GRAPH_TENANT_ID=
GRAPH_CLIENT_ID=
GRAPH_CLIENT_SECRET=
GRAPH_BOT_MAILBOX=                 # buzón bot que va en copia (CC) de las notificaciones
